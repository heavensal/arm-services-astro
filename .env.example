# FR/EN language switcher in the hero (routes /en/ stay available for SEO when false)
ENABLE_MULTILANG=false

# ContentForge: "true" to fetch FAQ from API; "false" uses fr.json / en.json (reviews are always from i18n)
CONTENTFORGE_ENABLED=false
CONTENTFORGE_URL=https://contentforge.1344.fr/api/v1
CONTENTFORGE_API_TOKEN=

# Contact form: ContentForge send_form (exposed to the browser — use a site token, not a global secret).
# PUBLIC_CONTACT_FORM_URL=https://contentforge.1344.fr/api/v1/send_form
# PUBLIC_CONTACT_FORM_TOKEN=your_site_bearer_token
PUBLIC_CONTACT_FORM_URL=https://contentforge.1344.fr/api/v1/send_form
PUBLIC_CONTACT_FORM_TOKEN=your_site_bearer_token

# --- SMTP (for the external POST handler only — not read by this static site) ---
# Typical OVH / Zimbra:
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contact@example.com
# SMTP_PASS=
# MAIL_FROM=contact@example.com
# MAIL_TO=contact@example.com
