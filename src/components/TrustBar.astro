---
/**
 * TrustBar — arguments de confiance affichés en barre horizontale.
 * Renforce la crédibilité sans logique, contenu statique.
 */
const items = [
	{ label: "Devis gratuit", icon: "✓" },
	{ label: "Assurance incluse", icon: "🛡" },
	{ label: "Déménageurs professionnels", icon: "👷" },
	{ label: "Intervention rapide", icon: "⚡" },
	{ label: "Matériel de protection", icon: "📦" },
];
---
<section class="bg-gray-100 border-y border-gray-200" aria-label="Nos engagements">
	<div class="container mx-auto px-4 py-6">
		<ul class="flex flex-wrap justify-center gap-6 md:gap-10 list-none m-0 p-0">
			{items.map((item) => (
				<li class="flex items-center gap-2 text-gray-700 font-medium">
					<span class="text-orange-armenian" aria-hidden="true">{item.icon}</span>
					<span>{item.label}</span>
				</li>
			))}
		</ul>
	</div>
</section>
