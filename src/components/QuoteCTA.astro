---
/**
 * QuoteCTA — bloc CTA devis avec photo handshake en arrière-plan.
 * Overlay pour lisibilité du texte. Responsive : background cover.
 */
import handshakeImage from '../assets/images/handshake.jpg';

interface Props {
	phone?: string;
	quoteUrl?: string;
}

const { phone = "06 43 09 65 97", quoteUrl = "#devis" } = Astro.props;
const telHref = `tel:${phone.replace(/\s/g, "")}`;
---
<section
	id="devis"
	class="relative min-h-[320px] md:min-h-[380px] py-16 md:py-24 bg-cover bg-center bg-no-repeat"
	style={`background-image: url(${handshakeImage.src});`}
	aria-labelledby="quote-cta-heading"
>
	<!-- Overlay pour lisibilité -->
	<div class="absolute inset-0 bg-blue-armenian/90" aria-hidden="true"></div>

	<div class="relative z-10 container mx-auto px-4 max-w-3xl text-center">
		<h2 id="quote-cta-heading" class="text-2xl md:text-3xl font-bold text-white mb-4">
			Obtenez votre devis gratuit
		</h2>
		<p class="text-white text-lg mb-8">
			Appelez-nous au {phone} ou demandez un devis en ligne. Réponse rapide, sans engagement.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a href={telHref} class="inline-flex items-center justify-center px-8 py-4 bg-white text-red-armenian font-semibold rounded-lg hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-blue-armenian">
				Appeler le {phone}
			</a>
			<a href={quoteUrl} class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-blue-armenian transition-colors">
				Demander un devis en ligne
			</a>
		</div>
	</div>
</section>
