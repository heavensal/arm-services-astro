---
/**
 * QuoteCTA — bloc CTA devis avec illustration (handshake = confiance).
 * Responsive : stack mobile, côte à côte desktop. SEO : alt descriptif, structure sémantique.
 */
import handshakeImage from '../assets/images/handshake.jpg';

interface Props {
	phone?: string;
	quoteUrl?: string;
}

const { phone = "06 43 09 65 97", quoteUrl = "#devis" } = Astro.props;
const telHref = `tel:${phone.replace(/\s/g, "")}`;
---
<section id="devis" class="bg-emerald-600" aria-labelledby="quote-cta-heading">
	<div class="container mx-auto px-4 max-w-6xl">
		<div class="flex flex-col lg:flex-row lg:items-center lg:gap-12 xl:gap-16">
			<!-- Illustration : en premier sur mobile (contexte), à gauche sur desktop -->
			<div class="flex-shrink-0 lg:w-2/5 xl:w-2/5 order-2 lg:order-1">
				<figure class="m-0">
					<img
						src={handshakeImage.src}
						alt="Équipe ARM Services à votre écoute pour établir votre devis de déménagement personnalisé"
						width={handshakeImage.width}
						height={handshakeImage.height}
						class="w-full h-auto object-cover rounded-xl shadow-lg lg:max-h-[400px] lg:object-center"
						fetchpriority="low"
						loading="lazy"
					/>
				</figure>
			</div>
			<!-- Contenu CTA -->
			<div class="py-12 md:py-16 lg:py-24 lg:w-3/5 order-1 lg:order-2 text-center lg:text-left">
				<h2 id="quote-cta-heading" class="text-2xl md:text-3xl font-bold text-white mb-4">
					Obtenez votre devis gratuit
				</h2>
				<p class="text-emerald-100 text-lg mb-8 max-w-xl lg:max-w-none mx-auto lg:mx-0">
					Appelez-nous au {phone} ou demandez un devis en ligne. Réponse rapide, sans engagement.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
					<a href={telHref} class="inline-flex items-center justify-center px-8 py-4 bg-white text-emerald-700 font-semibold rounded-lg hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-emerald-600">
						Appeler le {phone}
					</a>
					<a href={quoteUrl} class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-emerald-700 transition-colors">
						Demander un devis en ligne
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
