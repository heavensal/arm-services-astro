---
import { Image } from 'astro:assets';
import footerImage from '../assets/images/footer_team_delivery.jpg';

/**
 * Footer — mentions légales : ARM Services, SIRET, capital, contact.
 */
interface Props {
	phone?: string;
}

const { phone = "06 43 09 65 97" } = Astro.props;
const telHref = `tel:${phone.replace(/\s/g, "")}`;
---
<footer class="bg-gray-900 text-gray-300 w-full" role="contentinfo">
	<div class="flex flex-col md:flex-row min-h-full">
		<!-- Image Side: Full width square on phone, fixed width (stretch height) on desktop -->
		<div class="w-full aspect-square md:w-[450px] lg:w-[500px] md:aspect-auto shrink-0 relative flex">
			<Image 
				src={footerImage} 
				alt="Équipe ARM Services en plein déménagement" 
				class="w-full h-full object-cover absolute inset-0"
				width={800}
				height={800}
			/>
		</div>

		<!-- Informations Side -->
		<div class="flex-1 py-12 px-6 flex flex-col justify-center">
			<div class="max-w-xl mx-auto w-full">
				<div class="text-center md:text-left text-sm mb-8">
					<p class="font-semibold text-white mb-2 text-2xl">ARM Services</p>
					<p class="mb-6 text-base text-gray-400">Déménagement — Marseille & toute la France sur devis</p>
					<div class="flex flex-col flex-wrap md:items-start justify-center gap-4 mt-3 pb-2">
						<a href={telHref} class="text-orange-armenian hover:text-red-armenian flex items-center gap-2 text-lg">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
							{phone}
						</a>
						<a href="mailto:armservices86@gmail.com" class="text-orange-armenian hover:text-red-armenian flex items-center gap-2 text-lg">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							armservices86@gmail.com
						</a>
						<a href="https://www.tiktok.com/@arm.services86" target="_blank" rel="noopener noreferrer" class="text-orange-armenian hover:text-red-armenian flex items-center gap-2 text-lg">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.12-3.44-3.17-3.8-5.46-.4-2.51.56-5.17 2.47-6.84 1.79-1.53 4.37-2.1 6.6-1.78v4.06c-1.27-.33-2.65-.2-3.74.52-1.14.77-1.57 2.2-1.34 3.53.28 1.53 1.71 2.75 3.27 2.85 1.52.1 3.03-.66 3.73-2.02.43-.84.58-1.78.58-2.73 0-4.61-.01-9.22.01-13.84z"/></svg>
							@arm.services86
						</a>
					</div>
				</div>
				
				<hr class="border-gray-800 my-6" />

				<div class="flex flex-col lg:flex-row justify-between items-center lg:items-end gap-6 text-sm">
					<nav class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-2" aria-label="Mentions légales et politiques">
						<a href="/mentions-legales" class="text-gray-400 hover:text-white transition-colors">Mentions légales</a>
						<a href="/politique-confidentialite" class="text-gray-400 hover:text-white transition-colors">Politique de confidentialité</a>
						<a href="/conditions-generales" class="text-gray-400 hover:text-white transition-colors">Conditions générales</a>
					</nav>
					<p class="text-center lg:text-right text-gray-500 whitespace-nowrap">
						SIRET 938 889 334 00018<br />Capital social 6 300 €
					</p>
				</div>
			</div>
		</div>
	</div>
</footer>
