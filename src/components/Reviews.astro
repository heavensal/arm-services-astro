---
import { getFixedT, type Locale } from '../i18n/i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);

const reviews = [1, 2, 3, 4, 5].map((n) => ({
	name: t(`Reviews.r${n}n`),
	text: t(`Reviews.r${n}t`),
	stars: 5,
}));
---
<section class="py-16 md:py-24 bg-gray-50 overflow-hidden" aria-labelledby="reviews-heading">
	<div class="container mx-auto px-4 max-w-6xl">
		<h2 id="reviews-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-12">
			{t('Reviews.title')}
		</h2>

		<div class="relative -mx-4 md:mx-0">
			<div
				class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 px-4 md:px-0"
				style="scrollbar-width: thin;"
			>
				{reviews.map((review) => (
					<article
						class="flex-shrink-0 w-11/12 sm:w-96 max-w-sm snap-center bg-white rounded-xl shadow-md p-6 border border-gray-100"
					>
						<div class="flex items-center gap-1 mb-3" aria-label={t('Reviews.starsAria')}>
							{Array.from({ length: review.stars }).map(() => (
								<span class="text-amber-400" aria-hidden="true">★</span>
							))}
						</div>
						<p class="text-gray-700 mb-4">"{review.text}"</p>
						<p class="text-gray-500 font-medium">{review.name}</p>
					</article>
				))}
			</div>
		</div>

		<p class="text-center text-gray-500 text-sm mt-6">
			{t('Reviews.footer')}
		</p>
	</div>
</section>

<style>
	@media (hover: none) {
		.overflow-x-auto {
			-webkit-overflow-scrolling: touch;
		}
	}
</style>
