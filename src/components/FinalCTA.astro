---
import ContactFormDialog from './ContactFormDialog.astro';
import { getFixedT, type Locale } from '../i18n/i18n';
import { siteConfig } from '../site.config';

interface Props {
	locale: Locale;
	phone?: string;
}

const { locale, phone = '06 43 09 65 97' } = Astro.props;
const t = getFixedT(locale);
const telHref = `tel:${phone.replace(/\s/g, '')}`;
const email = siteConfig.contact.email;
---
<section id="contact" class="py-16 md:py-20 border-t border-gray-200" aria-label={t('FinalCTA.ariaLabel')}>
	<div class="container mx-auto px-4 max-w-2xl text-center">
		<p class="text-gray-600 mb-6">
			{t('FinalCTA.lead', { phone })}
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a href={telHref} class="cursor-pointer inline-flex items-center justify-center px-8 py-4 bg-orange-armenian text-white font-semibold rounded-lg hover:brightness-95 transition-colors">
				{t('FinalCTA.call', { phone })}
			</a>
		</div>
		<p class="mt-4 text-sm text-gray-600">
			{t('FinalCTA.emailInfoPrefix')}
			{' '}
			<a href={`mailto:${email}`} class="text-orange-armenian font-medium hover:text-red-armenian underline underline-offset-2">
				{email}
			</a>
		</p>
		<div class="mt-8 flex flex-col items-center gap-6">
			<ContactFormDialog locale={locale} />
			<a href={siteConfig.tiktokUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-600 hover:text-black transition-colors font-medium">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.12-3.44-3.17-3.8-5.46-.4-2.51.56-5.17 2.47-6.84 1.79-1.53 4.37-2.1 6.6-1.78v4.06c-1.27-.33-2.65-.2-3.74.52-1.14.77-1.57 2.2-1.34 3.53.28 1.53 1.71 2.75 3.27 2.85 1.52.1 3.03-.66 3.73-2.02.43-.84.58-1.78.58-2.73 0-4.61-.01-9.22.01-13.84z"/></svg>
				{t('FinalCTA.tiktok', { handle: siteConfig.tiktokHandle })}
			</a>
		</div>
	</div>
</section>
