---

import { getFixedT, type Locale } from '../i18n/i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getFixedT(locale);

const keys = ['s1', 's2', 's3', 's4', 's5'] as const;
const services = keys.map((k) => ({
	title: t(`Services.${k}t`),
	description: t(`Services.${k}d`),
}));

const staggerMs = 85;
const afterHeadingMs = 140;
/// <reference types="astro/client" />
---

<section
	id="services-section"
	class="services-reveal py-16 md:py-24"
	aria-labelledby="services-heading"
>
	<div class="container mx-auto px-4 max-w-6xl">
		<h2 id="services-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-12">
			{t('Services.title')}
		</h2>
		<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none m-0 p-0">
			{services.map((service, index) => (
				<li style={`--services-reveal-delay: ${afterHeadingMs + index * staggerMs}ms`}>
					<article class="h-full cursor-default rounded-xl p-6 bg-white border border-gray-200 shadow-sm hover:shadow-md">
						<h3 class="text-lg font-semibold text-gray-900 mb-2">{service.title}</h3>
						<p class="text-gray-600">{service.description}</p>
					</article>
				</li>
			))}
		</ul>
	</div>
</section>

<script>
	(() => {
		const section = document.getElementById('services-section');
		if (!section) return;

		const reveal = () => section.classList.add('is-in-view');

		if (!('IntersectionObserver' in window)) {
			reveal();
			return;
		}

		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					reveal();
					io.unobserve(entry.target);
				}
			},
			{ rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
		);

		io.observe(section);
	})();
</script>

<noscript>
	<style is:global>
		#services-section.services-reveal h2,
		#services-section.services-reveal li article {
			opacity: 1 !important;
			transform: none !important;
		}
	</style>
</noscript>
