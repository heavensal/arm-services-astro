---
/**
 * WhyUs — arguments commerciaux : fiabilité, expérience, sécurité.
 */
const points = [
	{ title: "Fiabilité", description: "Engagements tenus : dates et horaires respectés, devis détaillé sans surprise." },
	{ title: "Expérience", description: "Équipe formée aux bonnes pratiques du déménagement et au maniement des objets fragiles." },
	{ title: "Sécurité", description: "Assurance incluse, matériel de protection et véhicules adaptés pour vos biens." },
];
---
<section class="py-16 md:py-24 bg-gray-50" aria-labelledby="why-heading">
	<div class="container mx-auto px-4 max-w-6xl">
		<h2 id="why-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-12">
			Pourquoi nous choisir
		</h2>
		<ul class="grid grid-cols-1 md:grid-cols-3 gap-8 list-none m-0 p-0">
			{points.map((point) => (
				<li>
					<article class="text-center p-6">
						<h3 class="text-xl font-semibold text-gray-900 mb-2">{point.title}</h3>
						<p class="text-gray-600">{point.description}</p>
					</article>
				</li>
			))}
		</ul>
	</div>
</section>
