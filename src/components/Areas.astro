---
/**
 * Areas — zones desservies : basés à Marseille, intervention toute la France sur devis.
 */
const regions = [
	"Marseille", "Aix-en-Provence", "Toulon", "Nice", "Montpellier", "Lyon",
	"Paris", "Bordeaux", "Toulouse", "Nantes", "Strasbourg", "Lille",
	"Rennes", "Reims", "Saint-Étienne", "Grenoble", "Dijon", "Toute la France sur devis",
];
---
<section class="py-16 md:py-24" aria-labelledby="areas-heading">
	<div class="container mx-auto px-4 max-w-6xl">
		<h2 id="areas-heading" class="text-2xl md:text-3xl font-bold text-gray-900 text-center mb-4">
			Zones desservies
		</h2>
		<p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
			Basés à Marseille, ARM Services intervient dans toute la France sur devis.
		</p>
		<ul class="flex flex-wrap justify-center gap-3 list-none m-0 p-0">
			{regions.map((area) => (
				<li>
					<span class="inline-block px-4 py-2 bg-gray-100 text-gray-800 rounded-lg text-sm font-medium">
						{area}
					</span>
				</li>
			))}
		</ul>
	</div>
</section>
