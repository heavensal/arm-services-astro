---
/**
 * Hero — bannière plein écran, H1 SEO, CTA téléphone + ancre devis.
 */
import heroImage from '../assets/images/hero_truck.jpg';
import { getFixedT, type Locale } from '../i18n/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { siteConfig } from '../site.config';

interface Props {
	locale: Locale;
	phone?: string;
	quoteUrl?: string;
}

const { locale, phone = '06 43 09 65 97', quoteUrl = '#devis' } = Astro.props;
const t = getFixedT(locale);
const telHref = `tel:${phone.replace(/\s/g, '')}`;
const email = siteConfig.contact.email;
---
<section
	class="relative min-h-screen w-full flex flex-col justify-center px-4 py-20 bg-gray-900"
	aria-label={t('Hero.ariaLabel')}
>
	<LanguageSwitcher locale={locale} />
	<div class="absolute inset-0 z-0 fade-in fade-in-delay-2">
		<img
			src={heroImage.src}
			alt={t('Hero.imageAlt')}
			class="w-full h-full object-cover"
			fetchpriority="high"
		/>
		<div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
	</div>

	<div class="relative z-10 container mx-auto max-w-3xl text-center text-white">
		<div class="fade-in fade-in-delay-1">
			<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">
				{t('Hero.h1Line1')}
				<br /><span class="gradient-mask-armenian">{t('Hero.h1Line2')}</span><br />{
					t('Hero.h1Line3')
				}
			</h1>
			<p class="text-lg md:text-xl text-white/90 mb-3">
				{t('Hero.lead')}
			</p>
			<p class="text-sm md:text-base text-white/80 mb-8 max-w-xl mx-auto">
				{t('Hero.contactIntro', { phone })}
				<a
					href={`mailto:${email}`}
					class="text-orange-armenian underline decoration-orange-armenian/80 underline-offset-2 hover:text-white transition-colors"
				>
					{email}
				</a>
			</p>
		</div>
		<div class="flex flex-col sm:flex-row gap-4 justify-center fade-in fade-in-delay-3">
			<a
				href={telHref}
				class="cursor-pointer inline-flex items-center justify-center px-8 py-4 bg-orange-armenian text-white font-semibold rounded-lg hover:brightness-95 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-900"
			>
				{t('Hero.primaryCta', { phone })}
			</a>
			<a
				href={quoteUrl}
				class="cursor-pointer inline-flex items-center justify-center px-8 py-4 border-2 border-orange-armenian text-white font-semibold rounded-lg hover:bg-orange-armenian hover:text-white transition-colors"
			>
				{t('Hero.secondaryCta')}
			</a>
		</div>
	</div>
</section>
