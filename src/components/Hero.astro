---
/**
 * Hero — bannière plein écran avec image en fond, H1 SEO (déménagement + livraison), CTA principal = appeler.
 * L’image occupe tout le viewport (mobile et desktop).
 */
import heroImage from '../assets/images/hero_truck.jpg';

interface Props {
	phone?: string;
	quoteUrl?: string;
}

const { phone = "06 43 09 65 97", quoteUrl = "#devis" } = Astro.props;
const telHref = `tel:${phone.replace(/\s/g, "")}`;
---
<section
	class="relative min-h-screen w-full flex flex-col justify-center px-4 py-20 bg-gray-900"
	aria-label="Accueil ARM Services"
>
	<!-- Image + overlay : fade-in en 2e (après le texte) -->
	<div class="absolute inset-0 z-0 fade-in fade-in-delay-2">
		<img
			src={heroImage.src}
			alt="Camion de déménagement ARM Services"
			class="w-full h-full object-cover"
			fetchpriority="high"
		/>
		<div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
	</div>

	<div class="relative z-10 container mx-auto max-w-3xl text-center text-white">
		<!-- Texte : fade-in en 1er -->
		<div class="fade-in fade-in-delay-1">
			<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">
				ARM Services <br><span class="gradient-mask-armenian">Déménagement et Livraison</span><br> à Marseille &amp; partout en France
			</h1>
			<p class="text-lg md:text-xl text-white/90 mb-8">
				Basés à Marseille, nous intervenons sur toute la France sur devis. Devis gratuit, équipe pro, assurance incluse.
			</p>
		</div>
		<!-- Boutons : fade-in en 3e -->
		<div class="flex flex-col sm:flex-row gap-4 justify-center fade-in fade-in-delay-3">
			<a
				href={telHref}
				class="inline-flex items-center justify-center px-8 py-4 bg-orange-armenian text-white font-semibold rounded-lg hover:brightness-95 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-900"
			>
				Contactez-Nous
			</a>
			<a
				href={quoteUrl}
				class="inline-flex items-center justify-center px-8 py-4 border-2 border-orange-armenian text-white font-semibold rounded-lg hover:bg-orange-armenian hover:text-white transition-colors"
			>
				En Savoir Plus
			</a>
		</div>
	</div>
</section>
