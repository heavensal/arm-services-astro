---
import Layout from '../../layouts/Layout.astro';
import LandingHome from '../../components/LandingHome.astro';
import { getFixedT, type Locale } from '../../i18n/i18n';
import {
	buildHomeAlternateLanguages,
	buildLandingJsonLd,
	getAlternateLanguageUrls,
} from '../../lib/seo';

const locale: Locale = 'en';
const t = getFixedT(locale);

const alternates = getAlternateLanguageUrls(Astro.site);
const alternateLanguages = buildHomeAlternateLanguages(alternates);
const jsonLd = alternates ? buildLandingJsonLd(alternates) : undefined;
---

<Layout
	lang="en"
	ogLocale="en_US"
	ogLocaleAlternate="fr_FR"
	title={t('LandingPage.metaTitle')}
	description={t('LandingPage.metaDescription')}
	alternateLanguages={alternateLanguages}
	jsonLd={jsonLd}
	skipToContentLabel={t('Layout.skipToContent')}
	ogImageAlt={t('Layout.ogImageAlt')}
>
	<LandingHome locale={locale} />
</Layout>
