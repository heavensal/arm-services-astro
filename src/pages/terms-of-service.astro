---
import Layout from '../layouts/Layout.astro';
import TermsArticle from '../components/legal/TermsArticle.astro';
import { getFixedT, type Locale } from '../i18n/i18n';
import { absolutePageUrl, buildLegalAlternateLanguages } from '../lib/seo';
import { pageRoutes } from '../lib/paths';

const locale: Locale = 'fr';
const t = getFixedT(locale);
const frUrl = absolutePageUrl(Astro.site, pageRoutes.termsOfService);
const enUrl = absolutePageUrl(Astro.site, `en/${pageRoutes.termsOfService}`);
---

<Layout
	lang="fr"
	ogLocale="fr_FR"
	ogLocaleAlternate="en_US"
	title={t('Terms.metaTitle')}
	description={t('Terms.metaDescription')}
	alternateLanguages={buildLegalAlternateLanguages(frUrl, enUrl)}
	skipToContentLabel={t('Layout.skipToContent')}
>
	<TermsArticle locale={locale} />
</Layout>
