---
/**
 * Layout — SEO (title, description, canonical, Open Graph, Twitter),
 * hreflang, JSON-LD, favicon, skip-link, accessibilité.
 */
import '../styles/global.css';
import { pageHref } from '../lib/paths';
import { siteConfig } from '../site.config';

interface Props {
	title?: string;
	description?: string;
	/** Fichier dans public/ ou URL absolue pour OG */
	image?: string;
	robots?: string;
	lang?: string;
	ogLocale?: string;
	ogLocaleAlternate?: string;
	alternateLanguages?: { hreflang: string; href: string }[];
	jsonLd?: Record<string, unknown>;
	skipToContentLabel?: string;
	ogImageAlt?: string;
}

const {
	title: titleProp,
	description: descriptionProp,
	image: imageProp,
	robots = 'index, follow',
	lang: langProp,
	ogLocale: ogLocaleProp,
	ogLocaleAlternate,
	alternateLanguages,
	jsonLd,
	skipToContentLabel = 'Aller au contenu principal',
	ogImageAlt,
} = Astro.props;

const htmlLang = langProp ?? siteConfig.lang;
const ogLocale = ogLocaleProp ?? siteConfig.locale;
const pageTitle = titleProp ?? `${siteConfig.name} — ${siteConfig.tagline}`;
const description = descriptionProp ?? siteConfig.defaultDescription;

const canonical =
	Astro.site != null
		? new URL(Astro.url.pathname, Astro.site).href
		: undefined;

function absolutePublic(path: string): string | undefined {
	if (!Astro.site) return undefined;
	const p = path.startsWith('/') ? path.slice(1) : path;
	return new URL(import.meta.env.BASE_URL + p, Astro.site).href;
}

const ogImage =
	imageProp ??
	(siteConfig.ogImageUrl
		? siteConfig.ogImageUrl.startsWith('http')
			? siteConfig.ogImageUrl
			: absolutePublic(siteConfig.ogImageUrl)
		: undefined);

const jsonLdString = jsonLd
	? JSON.stringify(jsonLd).replace(/</g, '\\u003c')
	: null;

const base =
	import.meta.env.BASE_URL.endsWith('/')
		? import.meta.env.BASE_URL
		: `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content={siteConfig.themeColor} />
		<meta name="author" content={siteConfig.name} />

		<link rel="manifest" href={`${base}site.webmanifest`} />
		<link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
		<link rel="icon" type="image/svg+xml" href={pageHref('favicon.svg')} />
		<link rel="icon" href={`${base}favicon.ico`} sizes="any" />
		<link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
		<link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`} />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		{canonical && <link rel="canonical" href={canonical} />}
		{
			alternateLanguages?.map(({ hreflang, href }) => (
				<link rel="alternate" hreflang={hreflang} href={href} />
			))
		}

		<meta property="og:type" content="website" />
		<meta property="og:locale" content={ogLocale} />
		{
			ogLocaleAlternate && (
				<meta property="og:locale:alternate" content={ogLocaleAlternate} />
			)
		}
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		{canonical && <meta property="og:url" content={canonical} />}
		{ogImage && <meta property="og:image" content={ogImage} />}
		{
			ogImage && siteConfig.ogImageWidth > 0 && (
				<meta
					property="og:image:width"
					content={String(siteConfig.ogImageWidth)}
				/>
			)
		}
		{
			ogImage && siteConfig.ogImageHeight > 0 && (
				<meta
					property="og:image:height"
					content={String(siteConfig.ogImageHeight)}
				/>
			)
		}
		{ogImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}

		<meta
			name="twitter:card"
			content={ogImage ? 'summary_large_image' : 'summary'}
		/>
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{
			siteConfig.twitterHandle && (
				<meta
					name="twitter:site"
					content={`@${siteConfig.twitterHandle.replace(/^@/, '')}`}
				/>
			)
		}
		{ogImage && <meta name="twitter:image" content={ogImage} />}
		{ogImage && ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

		{jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
	</head>
	<body class="min-h-screen antialiased text-gray-900">
		<a class="skip-link" href="#main-content">{skipToContentLabel}</a>
		<slot />
	</body>
</html>
